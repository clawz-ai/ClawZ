{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "ClawZ",
  "version": "0.1.3",
  "identifier": "com.clawz.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "ClawZ",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "entitlements": "entitlements.plist"
    },
    "externalBin": [],
    "resources": {
      "../resources/openclaw/": "openclaw/",
      "../resources/NodeHelper.app/": "NodeHelper.app/",
      "../resources/node/": "node/",
      "../resources/cli/": "cli/"
    }
  }
}
