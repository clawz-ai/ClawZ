<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Required for Node.js V8 JIT compilation (without this, node crashes with SIGTRAP under Hardened Runtime) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <!-- Required to load native .node addons (koffi, etc.) that are not signed by the same certificate -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
